              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "registrations", "1"]
            }
          }
        }
      ]
    },
    {
      "name": "RBAC failure cases",
      "item": [
        {
          "name": "Create event WITHOUT token (401)",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('401 Unauthorized', () => pm.response.to.have.status(401));"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Unauthorized Event\",\n  \"description\": \"should fail\",\n  \"ticketPrice\": 10.00,\n  \"categoryId\": 1,\n  \"eventDate\": \"2026-08-01T10:00:00\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/v1/events",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "events"]
            }
          }
        },
        {
          "name": "Create event as USER (403)",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('403 Forbidden', () => pm.response.to.have.status(403));"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type",  "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{userToken}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"User-created Event\",\n  \"description\": \"should be forbidden\",\n  \"ticketPrice\": 10.00,\n  \"categoryId\": 1,\n  \"eventDate\": \"2026-08-01T10:00:00\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/v1/events",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "events"]
            }
          }
        },
        {
          "name": "List all registrations as USER (403)",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('403 Forbidden', () => pm.response.to.have.status(403));"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{userToken}}" }],
            "url": {
              "raw": "{{baseUrl}}/api/v1/registrations",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "registrations"]
            }
          }
        },
        {
          "name": "Delete event as USER (403)",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('403 Forbidden', () => pm.response.to.have.status(403));"
                ]
              }
            }
          ],
          "request": {
            "method": "DELETE",
            "header": [{ "key": "Authorization", "value": "Bearer {{userToken}}" }],
            "url": {
              "raw": "{{baseUrl}}/api/v1/events/1",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "events", "1"]
            }
          }
        },
        {
          "name": "Create registration WITHOUT token (401)",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('401 Unauthorized', () => pm.response.to.have.status(401));"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"items\": [ { \"eventId\": 1, \"quantity\": 1 } ]\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/v1/registrations",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "registrations"]
            }
          }
        },
        {
          "name": "Access with invalid token (401)",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('401 Unauthorized', () => pm.response.to.have.status(401));"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer not.a.real.token" }],
            "url": {
              "raw": "{{baseUrl}}/api/v1/registrations",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "registrations"]
            }
