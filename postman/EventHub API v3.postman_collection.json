{
  "info": {
    "_postman_id": "e9cc646f-d204-48e4-9f33-b1634a1edeaf",
    "name": "EventHub API v3",
    "description": "EventHub API — Assignment 3 (Security). Covers auth (register/login/password reset), RBAC (USER vs ADMIN), public endpoints, and 401/403 failure cases.\n\nUsage:\n1. Start the app (`./mvnw spring-boot:run`).\n2. Run the **Auth** folder first — login scripts automatically populate `userToken` and `adminToken` collection variables.\n3. All protected requests pick up the right token via `{{userToken}}` or `{{adminToken}}`.\n\nSeeded dev accounts (via `DevDataSeeder`, `dev` profile):\n- admin@eventhub.com / admin123  (ADMIN)\n- user@eventhub.com  / user123   (USER)",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl",     "value": "http://localhost:8080" },
    { "key": "userToken",   "value": "" },
    { "key": "adminToken",  "value": "" },
    { "key": "resetToken",  "value": "" }
  ],
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Register new user",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('201 Created', () => pm.response.to.have.status(201));",
                  "const body = pm.response.json();",
                  "pm.test('returns JWT', () => pm.expect(body.token).to.be.a('string').and.not.empty);",
                  "pm.collectionVariables.set('userToken', body.token);"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"newuser@example.com\",\n  \"firstName\": \"New\",\n  \"lastName\": \"User\",\n  \"password\": \"password123\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/v1/auth/register",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "auth", "register"]
            }
          }
        },
        {
          "name": "Login as USER",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('200 OK', () => pm.response.to.have.status(200));",
                  "const body = pm.response.json();",
                  "pm.test('returns JWT', () => pm.expect(body.token).to.be.a('string').and.not.empty);",
                  "pm.collectionVariables.set('userToken', body.token);"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"user@eventhub.com\",\n  \"password\": \"user123\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/v1/auth/login",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "auth", "login"]
            }
          }
        },
        {
          "name": "Login as ADMIN",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('200 OK', () => pm.response.to.have.status(200));",
                  "const body = pm.response.json();",
                  "pm.test('role is ADMIN', () => pm.expect(JSON.stringify(body)).to.include('ADMIN'));",
                  "pm.collectionVariables.set('adminToken', body.token);"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"admin@eventhub.com\",\n  \"password\": \"admin123\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/v1/auth/login",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "auth", "login"]
            }
          }
        },
        {
          "name": "Login with wrong password (401)",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('401 Unauthorized', () => pm.response.to.have.status(401));"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"user@eventhub.com\",\n  \"password\": \"wrongpassword\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/v1/auth/login",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "auth", "login"]
            }
          }
        },
        {
          "name": "Request password reset",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('200 OK', () => pm.response.to.have.status(200));",
                  "const body = pm.response.json();",
                  "if (body.resetToken) { pm.collectionVariables.set('resetToken', body.resetToken); }"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"user@eventhub.com\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/v1/auth/password-reset-request",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "auth", "password-reset-request"]
            }
          }
        },
        {
          "name": "Reset password with token",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('200 OK', () => pm.response.to.have.status(200));"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"token\": \"{{resetToken}}\",\n  \"newPassword\": \"newSecret123\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/v1/auth/password-reset",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "auth", "password-reset"]
            }
          }
        }
      ]
    },
    {
      "name": "Public (no auth)",
      "item": [
        {
          "name": "List all events (paginated)",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/v1/events",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "events"]
            }
          }
        },
        {
          "name": "Filter by category (Music)",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/v1/events?category=Music",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "events"],
              "query": [{ "key": "category", "value": "Music" }]
            }
          }
        },
        {
          "name": "Filter by price range",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
