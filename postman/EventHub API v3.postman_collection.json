              "query": [
                { "key": "startDate", "value": "2026-04-01" },
                { "key": "endDate",   "value": "2026-06-30" }
              ]
            }
          }
        },
        {
          "name": "Sort by ticketPrice desc",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/v1/events?sort=ticketPrice,desc",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "events"],
              "query": [{ "key": "sort", "value": "ticketPrice,desc" }]
            }
          }
        },
        {
          "name": "Get event by ID",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/v1/events/2",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "events", "2"]
            }
          }
        },
        {
          "name": "List all categories",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/v1/categories",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "categories"]
            }
          }
        },
        {
          "name": "Get category by ID",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/v1/categories/1",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "categories", "1"]
            }
          }
        }
      ]
    },
    {
      "name": "USER role",
      "item": [
        {
          "name": "Create registration",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type",  "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{userToken}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"items\": [\n    { \"eventId\": 1, \"quantity\": 2 },\n    { \"eventId\": 3, \"quantity\": 1 }\n  ]\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/v1/registrations",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "registrations"]
            }
          }
        },
        {
          "name": "Get registrations by user",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{userToken}}" }],
            "url": {
              "raw": "{{baseUrl}}/api/v1/registrations/user/1",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "registrations", "user", "1"]
            }
          }
        },
        {
          "name": "Cancel a registration",
          "request": {
            "method": "PATCH",
            "header": [{ "key": "Authorization", "value": "Bearer {{userToken}}" }],
            "url": {
              "raw": "{{baseUrl}}/api/v1/registrations/1/cancel",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "registrations", "1", "cancel"]
            }
          }
        }
      ]
    },
    {
      "name": "ADMIN role",
      "item": [
        {
          "name": "Create category",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type",  "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{adminToken}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Workshops\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/v1/categories",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "categories"]
            }
          }
        },
        {
          "name": "Create event",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type",  "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{adminToken}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Spring Boot Workshop\",\n  \"description\": \"Learn Spring Boot fundamentals\",\n  \"ticketPrice\": 25.00,\n  \"categoryId\": 2,\n  \"eventDate\": \"2026-07-15T10:00:00\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/v1/events",
